---
interface Props {
	colors?: string[];
	id?: number;
	isSale?: boolean;
	originalPrice?: string;
	price: string;
	thumbnail?: string;
	title: string;
}

const {
	id,
	title,
	price,
	originalPrice,
	isSale = false,
	colors = [],
	thumbnail,
} = Astro.props;

const Element = id ? "a" : "div";
const href = id ? `/products/${id}` : undefined;
---

<Element class="group relative flex flex-col gap-4" href={href}>
  <div class="aspect-270/320 w-full overflow-hidden bg-brand-light-bg">
    <img
      alt={title}
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      src={thumbnail || "/images/placeholder.jpg"}
    >
  </div>

  <div class="flex flex-col-reverse md:flex-row gap-1.5 justify-between">
    <div class="flex flex-col gap-1.5">
      <h3
        class="text-base font-semibold text-brand-dark leading-normal line-clamp-2 font-display"
      >
        {title}
      </h3>
      <div
        class="flex flex-col-reverse md:flex-row md:items-baseline gap-2 text-base leading-normal"
      >
        <span class="text-brand-dark">{price}</span>
        {originalPrice && (
				<span class="text-sm text-brand-dark/50 line-through">
					{originalPrice}
				</span>
			)}
      </div>
    </div>
    {isSale && (
    	<div class="inline-flex h-5.5 w-11.25 items-center justify-center bg-brand-navy px-2.5 py-1 text-[10px] font-normal text-white">
    		SALE
    	</div>
    )}
  </div>

  {colors.length > 0 && (
		<div class="flex gap-1.5 mt-1">
			{colors.map((color) => (
				<div
					class="h-1.5 w-5 rounded-full"
					style={{ backgroundColor: color }}
				/>
			))}
		</div>
	)}
</Element>
